phase3_data <- read_excel("~/OneDrive - University of South Florida/Phase3_Tracker_Gamma_Verified.xlsx")
# 2. Clean and bucket the raw education variable
phase3_model_ready <- phase3_data %>%
mutate(
# Standardize the raw text: lowercase and strip hidden spaces
edu_raw = str_trim(tolower(as.character(cro_education))),
# THE SORTING HAT: Assigning statistical buckets
cro_edu_category = case_when(
# Healthcare Heavyweights
grepl("md|doctor|pharm|med|rn|bsn|physician|health", edu_raw) ~ "Medical/Science",
# Energy & Utility Heavyweights
grepl("eng|enviro|geol|chem|physics|hse|science", edu_raw) ~ "Engineering/STEM",
# The Traditional Governance Roles
grepl("jd|law|legal|esq|counsel|lawyer", edu_raw) ~ "Legal",
grepl("cpa|acc|audit", edu_raw) ~ "Accounting",
grepl("mba|fin|bus|ba|econ|admin|management", edu_raw) ~ "General Business",
# No CRO present (handling NAs and blanks)
is.na(edu_raw) | edu_raw %in% c("nan", "none", "", "0", "na") ~ "None",
# Catch anything that slipped through the cracks
TRUE ~ "Other"
),
# Ensure your binary variables are strictly numeric for the regression
cro_present = as.numeric(cro_present),
risk_committee = as.numeric(risk_committee)
)
# 3. The Moment of Truth: View the breakdown by sector!
table(phase3_model_ready$cro_edu_category, phase3_model_ready$gsector)
# 1. Set "None" as the baseline category so every degree is compared against having no CRO
phase3_model_ready$cro_edu_category <- relevel(as.factor(phase3_model_ready$cro_edu_category), ref = "None")
# 2. Run the regression model predicting Gamma!
# Note: We are controlling for firm size (at) since we didn't filter it out entirely
phase3_regression <- lm(gamma ~ cro_edu_category + risk_committee + log(at), data = phase3_model_ready)
# 3. View the statistical results
summary(phase3_regression)
library(dplyr)
library(tidyr)
# 1. THE BRIDGE: Grab the CIK codes from your raw Compustat data
cik_mapper <- compustat_data %>%
select(tic, cik) %>%
distinct() %>%
filter(!is.na(cik))
# 2. Attach the CIK codes to your Phase 3 firms
firm_list <- phase3_data %>%
select(tic, conm, gsector) %>%
distinct() %>%
left_join(cik_mapper, by = "tic") %>%
# Force it to numeric so it matches BoardEx perfectly
mutate(cikcode = as.numeric(cik))
# 3. Expand those firms across 19 years (2000 to 2018)
panel_template <- firm_list %>%
crossing(fyear = 2000:2018)
# 4. Prep the BoardEx data for the Time Machine
boardex_historical <- Individual_Profile_Employment %>%
mutate(
# Extract the start year
start_year = as.numeric(substr(as.character(datestartrole), 1, 4)),
# If end_year is blank, assume they are still active (use 2024 as a placeholder)
end_year = ifelse(is.na(dateendrole), 2024, as.numeric(substr(as.character(dateendrole), 1, 4))),
# Clean titles
title_clean = tolower(rolename)
) %>%
# Filter for the Risk/Compliance/Regulatory keywords
filter(grepl("risk|compliance|regulatory|quality|hse|safety|audit", title_clean)) %>%
select(cikcode, rolename, start_year, end_year)
# 5. The Time Machine Merge:
historical_panel <- panel_template %>%
# Check if 'fyear' falls between start and end dates
left_join(boardex_historical,
by = join_by(cikcode == cikcode, fyear >= start_year, fyear <= end_year)) %>%
# Group by the firm and year to collapse multiple executives into a single 1 or 0
group_by(tic, conm, gsector, fyear, cikcode) %>%
summarise(
# If R found at least one matching executive in that year, code as 1, else 0
cro_present = ifelse(sum(!is.na(rolename)) > 0, 1, 0),
.groups = "drop"
)

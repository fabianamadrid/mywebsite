library(dplyr)
library(stringr)
# 1. Merge the Gamma scores and Assets into the Master Panel
final_master_model <- master_panel %>%
# Attach the gvkey and asset data using our mapper from earlier
left_join(gvkey_mapper, by = "tic") %>%
mutate(gvkey = str_pad(as.character(gvkey), width = 6, side = "left", pad = "0")) %>%
# Bring in the historical Gamma scores
left_join(gamma_data_clean %>% select(gvkey, year, gamma),
by = c("gvkey" = "gvkey", "fyear" = "year")) %>%
# Drop the years where Gamma scores weren't calculated/available
filter(!is.na(gamma)) %>%
# THE CATALYST: Create the binary dummy variable for the IT Sector
mutate(is_IT = ifelse(gsector == "Information Technology", 1, 0))
# 2. Check the final sample size for the regression
print(paste("Firms/Years ready for the final model:", nrow(final_master_model)))
# 3. RUN THE ULTIMATE INTERACTION REGRESSION
# We use cro_present:is_IT to test if the CRO's effect is statistically different in IT vs others
master_regression <- lm(gamma ~ cro_present + cro_present:is_IT + log(at) + factor(tic) + factor(fyear),
data = final_master_model)
# 4. Extract and print the results beautifully
results_master <- coef(summary(master_regression))
# We only want to see our core variables, hiding the thousands of firm/year fixed effects
core_vars <- c("cro_present", "cro_present:is_IT", "log(at)")
results_master_clean <- results_master[rownames(results_master) %in% core_vars, ]
print("--- THE FINAL MASTER REGRESSION RESULTS ---")
print(results_master_clean)
library(dplyr)
library(stringr)
# 1. Extract Board Size and CEO Duality from the BoardEx File
governance_controls <- Individual_Profile_Employment %>%
mutate(
cikcode = as.numeric(cikcode),
start_year = as.numeric(substr(as.character(datestartrole), 1, 4)),
end_year = ifelse(is.na(dateendrole), 2024, as.numeric(substr(as.character(dateendrole), 1, 4))),
title_clean = tolower(rolename)
) %>%
# Filter only for the 67 CIKs in our study to speed up the math
filter(cikcode %in% unique(final_master_model$cikcode)) %>%
# Cross with our 2000-2018 timeline
inner_join(data.frame(fyear = 2000:2018), by = character()) %>%
filter(fyear >= start_year & fyear <= end_year) %>%
# Calculate the metrics per firm-year
group_by(cikcode, fyear) %>%
summarise(
# Board Size: Count unique directors where brdposition is "Yes"
board_size = n_distinct(directorname[tolower(brdposition) == "yes" | tolower(brdposition) == "y"]),
# CEO Duality: Check if anyone holds both "CEO" and "Chairman" in the same year
ceo_duality = ifelse(any(grepl("ceo|chief executive", title_clean) & grepl("chairman", title_clean)), 1, 0),
.groups = "drop"
)
# 2. Merge these new variables into our existing Master Model
h3_master_model <- final_master_model %>%
left_join(governance_controls, by = c("cikcode", "fyear")) %>%
# Fill any NAs with the median board size (safety measure)
mutate(
board_size = ifelse(is.na(board_size) | board_size == 0, median(board_size, na.rm = TRUE), board_size),
ceo_duality = ifelse(is.na(ceo_duality), 0, ceo_duality)
)
# 3. RUN THE EXPANDED REGRESSION FOR HYPOTHESIS 3
h3_regression <- lm(gamma ~ cro_present + cro_present:is_IT + board_size + ceo_duality + log(at) + factor(tic) + factor(fyear),
data = h3_master_model)
# 4. Print the clean results
results_h3 <- coef(summary(h3_regression))
core_vars_h3 <- c("cro_present", "cro_present:is_IT", "board_size", "ceo_duality", "log(at)")
results_h3_clean <- results_h3[rownames(results_h3) %in% core_vars_h3, ]
print("--- HYPOTHESIS 3: EXPANDED GOVERNANCE MODEL ---")
print(results_h3_clean)
library(dplyr)
library(dplyr)
library(dplyr)
# 1. Extract the missing financial controls from your raw Compustat data
financial_controls <- compustat_data %>%
filter(!is.na(at) & at > 0 & !is.na(fyear)) %>%
mutate(
# Profitability: Return on Assets (Net Income / Total Assets)
profitability = ni / at,
# Leverage: Total Debt (Long-Term + Current) / Total Assets
# We use ifelse to treat missing debt as 0 so the math doesn't break
leverage = (ifelse(is.na(dltt), 0, dltt) + ifelse(is.na(dlc), 0, dlc)) / at,
# Market-to-Book: (Stock Price * Shares Outstanding) / Book Value of Equity
mtb = (prcc_f * csho) / ceq
) %>%
# Select only what we need to merge
select(tic, fyear, profitability, leverage, mtb) %>%
# Remove any accidental duplicates
distinct(tic, fyear, .keep_all = TRUE)
# 2. Merge the financial controls into our H3 Master Model
final_full_model <- h3_master_model %>%
left_join(financial_controls, by = c("tic", "fyear")) %>%
# Safety Check: Clean up any infinite values or NAs caused by dividing by zero
mutate(
profitability = ifelse(is.finite(profitability), profitability, median(profitability, na.rm=TRUE)),
leverage = ifelse(is.finite(leverage), leverage, median(leverage, na.rm=TRUE)),
mtb = ifelse(is.finite(mtb), mtb, median(mtb, na.rm=TRUE))
)
# 3. RUN THE ULTIMATE PROSPECTUS REGRESSION
prospectus_regression <- lm(gamma ~ cro_present + cro_present:is_IT +
board_size + ceo_duality +
log(at) + profitability + leverage + mtb +
factor(tic) + factor(fyear),
data = final_full_model)
# 4. Extract and print the beautiful results
results_prospectus <- coef(summary(prospectus_regression))

library(dplyr)
library(stringr)
# 1. THE BRIDGE: We need gvkey and assets to merge the Gamma data properly
gvkey_mapper <- compustat_data %>%
select(tic, gvkey, at) %>%
# Just grab the most recent asset size for the control variable
group_by(tic) %>%
slice_max(fyear, n = 1) %>%
ungroup() %>%
select(tic, gvkey, at)
# 2. Merge Gamma scores into your 18-year panel
final_panel_model <- historical_panel %>%
left_join(gvkey_mapper, by = "tic") %>%
# Pad the gvkey
mutate(gvkey = str_pad(as.character(gvkey), width = 6, side = "left", pad = "0")) %>%
# Bring in the historical Gamma scores!
left_join(gamma_data_clean %>% select(gvkey, year, gamma),
by = c("gvkey" = "gvkey", "fyear" = "year")) %>%
# Drop the years where Gamma scores weren't calculated/available
filter(!is.na(gamma))
library(dplyr)
library(stringr)
# 1. THE BRIDGE: Create the gvkey_mapper safely
gvkey_mapper <- compustat_data %>%
# Safety check: drop rows missing the asset or year data
filter(!is.na(at) & !is.na(fyear)) %>%
select(tic, gvkey, at, fyear) %>%
group_by(tic) %>%
# Sort by year (newest first) and grab the top row for each firm
arrange(desc(fyear)) %>%
slice(1) %>%
ungroup() %>%
select(tic, gvkey, at)
# 2. Merge Gamma scores into your 18-year panel
final_panel_model <- historical_panel %>%
left_join(gvkey_mapper, by = "tic") %>%
# Pad the gvkey so it matches the Gamma data perfectly
mutate(gvkey = str_pad(as.character(gvkey), width = 6, side = "left", pad = "0")) %>%
# Bring in the historical Gamma scores
left_join(gamma_data_clean %>% select(gvkey, year, gamma),
by = c("gvkey" = "gvkey", "fyear" = "year")) %>%
# Drop the years where Gamma scores weren't calculated/available
filter(!is.na(gamma))
# 3. Check the final sample size for the regression
print(paste("Firms/Years with matching Gamma scores:", nrow(final_panel_model)))
# 4. RUN THE FIXED EFFECTS PANEL REGRESSION
panel_regression <- lm(gamma ~ cro_present + log(at) + factor(tic) + factor(fyear),
data = final_panel_model)
# 5. Extract just the variables we care about (Hiding the 60+ firm/year controls)
results <- coef(summary(panel_regression))
results_clean <- results[c("cro_present", "log(at)"), ]
print("--- PANEL REGRESSION RESULTS ---")
print(results_clean)
print(results_clean)
